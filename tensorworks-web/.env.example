# ── Database ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/tensorworks"

# ── HubSpot ───────────────────────────────────────────────────────
HUBSPOT_API_KEY="your-hubspot-private-app-token"
HUBSPOT_PORTAL_ID="your-portal-id"

# ── Resend ────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
FROM_EMAIL="sales@tensorworks.online"
NOTIFICATION_EMAIL="sam@tensorworks.online,sales@tensorworks.online"

# ── Cloudflare Turnstile ──────────────────────────────────────────
TURNSTILE_SECRET_KEY="your-turnstile-secret-key"
NEXT_PUBLIC_TURNSTILE_SITE_KEY="your-turnstile-site-key"

# ── Admin auth ────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET="change-this-to-a-random-string-at-least-32-chars"
# Comma-separated list of allowed admin email addresses
ADMIN_EMAILS="sam@tensorworks.online"

# ── Site ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://tensorworks.online"
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# ── Company (optional — defaults shown) ──────────────────────────
# COMPANY_NAME="TensorWorks Pty Ltd"
# COMPANY_ABN="84 544 119 830"
# COMPANY_ADDRESS="Bendigo, Victoria, Australia"

# ── Redis (required for worker / news monitoring) ────────────────
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD="devpassword"

# ── Anthropic (required for content generation worker) ───────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── Editorial budget ──────────────────────────────────────────────
# Maximum monthly AI spend in AUD before generation halts
MONTHLY_AI_BUDGET_AUD="500"

# ── Mailchimp ─────────────────────────────────────────────────────
# API key from Mailchimp Account → Extras → API Keys
MAILCHIMP_API_KEY="your-api-key"
# Server prefix — last part of API key, e.g. "us21"
MAILCHIMP_SERVER_PREFIX="us21"
# Audience (list) ID from Mailchimp → Audience → Settings → Audience name and campaign defaults
MAILCHIMP_AUDIENCE_ID="your-audience-id"
# Sender identity (must be verified in Mailchimp)
MAILCHIMP_FROM_NAME="TensorWorks"
MAILCHIMP_FROM_EMAIL="newsletter@tensorworks.com.au"
MAILCHIMP_REPLY_TO="hello@tensorworks.com.au"
# Random string — set in Mailchimp webhook URL as ?secret=value
MAILCHIMP_WEBHOOK_SECRET="change-this-to-a-random-string"

# ── Consent export backup (S3-compatible, e.g. Backblaze B2) ─────
# Optional — if not set, exports are written to ./exports/ locally
# BACKUP_S3_ENDPOINT="https://s3.us-west-004.backblazeb2.com"
# BACKUP_S3_BUCKET="tensorworks-consent-exports"
# BACKUP_S3_ACCESS_KEY="your-access-key"
# BACKUP_S3_SECRET_KEY="your-secret-key"
