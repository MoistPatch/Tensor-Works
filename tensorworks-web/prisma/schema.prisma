generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
}

model RFQSubmission {
  id                     String   @id @default(cuid())
  createdAt              DateTime @default(now())
  companyName            String
  abn                    String?
  contactName            String
  role                   String
  email                  String
  phone                  String
  organisationType       String
  useCase                String
  budgetBracket          String
  timeline               String
  specifications         String   @db.Text
  procurementConstraints String[]
  referralSource         String?
  hubspotContactId       String?
  hubspotDealId          String?
  ipAddress              String?
  userAgent              String?
  status                 String   @default("new")
}

model RFQDraft {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  data      Json
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model AdminSession {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model MagicLinkToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model AuditLog {
  id         String   @id @default(cuid())
  actorEmail String
  action     String
  target     String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
}

// ─── Blog / Editorial ────────────────────────────────────────────────────────

model BlogPost {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  subtitle        String?
  category        String
  tier            String    // "daily-scan" | "weekly-digest" | "deep-analysis"
  status          String    @default("draft") // "draft" | "pending_review" | "approved" | "published" | "rejected"
  body            String    @db.Text
  summary         String    @db.Text
  citations       Json      @default("[]") // Array<{ title: string; url: string; accessed: string }>
  tags            String[]
  coverImageUrl   String?
  authorLabel     String    @default("TensorWorks Engineering")
  readingTimeMin  Int       @default(5)
  wordCount       Int       @default(0)
  generationCost  Float?    // AUD
  modelUsed       String?
  promptTokens    Int?
  completionTokens Int?
  publishedAt     DateTime?
  scheduledFor    DateTime?
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNotes     String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  generationLog   GenerationLog?
  editorialEntry  EditorialCalendar? @relation("CalendarPost")
}

model EditorialCalendar {
  id              String    @id @default(cuid())
  topic           String
  description     String    @db.Text
  category        String
  tier            String
  targetWeek      DateTime? // ISO week start
  status          String    @default("queued") // "queued" | "assigned" | "generated" | "skipped"
  priority        Int       @default(50)
  adminOverride   Boolean   @default(false)
  postId          String?   @unique
  post            BlogPost? @relation("CalendarPost", fields: [postId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model GenerationLog {
  id              String   @id @default(cuid())
  postId          String   @unique
  post            BlogPost @relation(fields: [postId], references: [id])
  jobName         String
  model           String
  promptTokens    Int
  completionTokens Int
  costAud         Float
  qualityScore    Float?
  qualityReport   Json?
  researchUrls    String[]
  attempts        Int      @default(1)
  createdAt       DateTime @default(now())
}

// ─── News Monitoring ──────────────────────────────────────────────────────────

model NewsSource {
  id           String    @id @default(cuid())
  name         String
  url          String    @unique
  feedUrl      String?
  fetchType    String    // "rss" | "api" | "scrape"
  category     String
  active       Boolean   @default(true)
  trustScore   Float     @default(0.5)
  lastFetchedAt DateTime?
  fetchErrors  Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  items        NewsItem[]
}

model NewsItem {
  id              String    @id @default(cuid())
  sourceId        String
  source          NewsSource @relation(fields: [sourceId], references: [id])
  externalId      String?
  title           String
  url             String
  summary         String?   @db.Text
  fullText        String?   @db.Text
  publishedAt     DateTime?
  fetchedAt       DateTime  @default(now())
  relevanceScore  Float?
  sentimentScore  Float?
  banned          Boolean   @default(false)
  clusterId       String?
  cluster         TriangulationGroup? @relation(fields: [clusterId], references: [id])
  createdAt       DateTime  @default(now())

  @@unique([sourceId, url])
}

model TriangulationGroup {
  id           String     @id @default(cuid())
  topic        String
  summary      String?    @db.Text
  itemCount    Int        @default(0)
  avgRelevance Float?
  status       String     @default("pending") // "pending" | "reviewed" | "used" | "dismissed"
  usedInPostId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  items        NewsItem[]
}

model BannedClaim {
  id          String   @id @default(cuid())
  pattern     String   @unique
  reason      String
  addedBy     String
  createdAt   DateTime @default(now())
}

// ─── Email Marketing ──────────────────────────────────────────────────────────

model NewsletterSubscriber {
  id                     String    @id @default(cuid())
  email                  String    @unique
  firstName              String?
  lastName               String?
  organisation           String?
  roleTitle              String?
  consentBasis           String                     // express | inferred_rfq | inferred_business | deemed_published
  consentSource          String                     // form_blog_footer | form_post_inline | rfq_opt_in | manual_import | api
  consentTimestamp       DateTime  @default(now())
  consentIp              String?
  consentNote            String?
  mailchimpId            String?   @unique
  tags                   String[]
  status                 String    @default("pending") // pending | active | unsubscribed | bounced | complained
  doubleOptInConfirmedAt DateTime?
  unsubscribedAt         DateTime?
  unsubscribeReason      String?
  bouncedAt              DateTime?
  bounceType             String?                    // soft | hard
  complainedAt           DateTime?
  lastEngagedAt          DateTime?
  createdAt              DateTime  @default(now())

  @@index([status])
  @@index([tags])
}

model EmailCampaign {
  id                  String    @id @default(cuid())
  blogPostId          String?
  type                String                         // weekly_digest_email | post_announcement | welcome_1 | welcome_2 | welcome_3 | cold_intro | reengagement | manual_broadcast
  segmentTag          String
  subjectLine         String
  previewText         String
  bodyMjml            String    @db.Text
  bodyHtml            String    @db.Text
  bodyText            String    @db.Text
  status              String    @default("draft")    // draft | in_review | approved | scheduled | sent | failed
  scheduledFor        DateTime?
  sentAt              DateTime?
  mailchimpCampaignId String?
  recipientCount      Int?
  deliveredCount      Int?
  openCount           Int?
  clickCount          Int?
  unsubscribeCount    Int?
  bounceCount         Int?
  complaintCount      Int?
  generatedBy         String?
  reviewedBy          String?
  approvedAt          DateTime?
  createdAt           DateTime  @default(now())

  @@index([status, scheduledFor])
  @@index([type, sentAt])
}

model UnsubscribeToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime
}
